<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blurback"
    android:padding="16dp">

    <!-- Top Image Icon -->

    <!-- Header: Directorate of Commercial Taxes -->

    <TextView
        android:id="@+id/textView6"
        android:layout_width="100dp"
        android:layout_height="25dp"
        android:layout_marginEnd="80dp"
        android:text="Upload Photo"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageButton2"
        app:layout_constraintVertical_bias="0.138" />

    <ImageView
        android:id="@+id/top_image"
        android:layout_width="203dp"
        android:layout_height="146dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ashok"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sub-header: Finance Department -->

    <!-- Sub-header: Government of West Bengal -->

    <!-- Button: Search by GSTIN -->

    <!-- Button: Show Dealer Details -->

    <!-- Button: Data Export -->

    <!-- Button: Already Completed Survey -->

    <TextView
        android:id="@+id/header_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Directorate of Commercial Taxes"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_image" />

    <TextView
        android:id="@+id/sub_header_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finance Department"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="171dp"
        tools:layout_editor_absoluteY="160dp" />

    <TextView
        android:id="@+id/government_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sub_header_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Government of West Bengal"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="155dp"
        tools:layout_editor_absoluteY="228dp" />


    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="44dp"
        android:text="Developed and Designed by CTD"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Dealer Details"
        android:textColor="@android:color/white"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/government_text" />

    <TableLayout
        android:id="@+id/tableLayout"
        android:layout_width="361dp"
        android:layout_height="290dp"
        android:layout_marginTop="16dp"
        android:stretchColumns="1"
        app:layout_constraintTop_toBottomOf="@+id/textView5"
        tools:layout_editor_absoluteX="1dp">

        <TableRow>

            <TextView
                android:id="@+id/gstin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="GSTIN:"
                android:textColor="@android:color/white"
                android:textSize="18dp"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="68dp"
                tools:layout_editor_absoluteY="327dp" />

            <TextView
                android:id="@+id/gstinno"
                android:layout_width="191dp"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:text="1"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="258dp"
                tools:layout_editor_absoluteY="325dp"
                android:textSize="15dp"/>

        </TableRow>

        <TableRow>

            <TextView
                android:id="@+id/tradenm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Trade Name:"
                android:textColor="@android:color/white"
                android:textSize="18dp"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="68dp"
                tools:layout_editor_absoluteY="378dp" />

            <TextView
                android:id="@+id/trade_nm"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:ellipsize="none"
                android:gravity="start"
                android:maxLines="5"
                android:padding="20dp"
                android:textStyle="bold"
                android:scrollHorizontally="false"
                android:text="2"
                android:textColor="@android:color/white"
                android:textSize="15sp" />

        </TableRow>

        <TableRow>

            <TextView
                android:id="@+id/legalnm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Legal Name:"
                android:textColor="@android:color/white"
                android:textSize="18dp"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="69dp"
                tools:layout_editor_absoluteY="426dp" />

            <TextView
                android:id="@+id/legal_nm"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:ellipsize="none"
                android:gravity="start"
                android:maxLines="5"
                android:padding="20dp"
                android:textStyle="bold"
                android:scrollHorizontally="false"
                android:text="3"
                android:textColor="@android:color/white"
                android:textSize="15dp" />
        </TableRow>

        <TableRow>

            <TextView
                android:id="@+id/addr"
                android:layout_width="93dp"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:text="Address:"
                android:textColor="@android:color/white"
                android:textSize="18dp"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="69dp"
                tools:layout_editor_absoluteY="479dp" />

            <TextView
                android:id="@+id/address"
                android:layout_width="188dp"
                android:layout_height="match_parent"
                android:ellipsize="none"
                android:gravity="start"
                android:maxLines="5"
                android:textStyle="bold"
                android:padding="20dp"
                android:scrollHorizontally="false"
                android:text="4"
                android:textColor="@android:color/white"
                android:textSize="15dp" />
        </TableRow>
    </TableLayout>

    <TextView
        android:id="@+id/userid_text"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:text="User"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/textView5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.068"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/government_text" />

    <ImageButton
        android:id="@+id/imageButton2"
        android:layout_width="95dp"
        android:layout_height="45dp"
        android:layout_marginBottom="52dp"
        android:scaleType="fitCenter"
        android:tooltipText="Show address in map"
        android:background="@drawable/edittext_rounded_bg"
        app:layout_constraintBottom_toTopOf="@+id/textView2"
        app:layout_constraintEnd_toStartOf="@+id/upload_pic_btn"
        app:layout_constraintHorizontal_bias="0.584"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tableLayout"
        app:layout_constraintVertical_bias="0.518"
        app:srcCompat="@drawable/marker" />

    <ImageButton
        android:id="@+id/upload_pic_btn"
        android:layout_width="95dp"
        android:layout_height="45dp"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toTopOf="@+id/textView2"
        android:background="@drawable/edittext_rounded_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tableLayout"
        app:srcCompat="@android:drawable/ic_menu_camera" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="63dp"
        android:layout_height="22dp"
        android:text="Location"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/textView6"
        app:layout_constraintHorizontal_bias="0.602"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageButton2"
        app:layout_constraintVertical_bias="0.136" />


</androidx.constraintlayout.widget.ConstraintLayout>
